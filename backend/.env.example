# Gemini API
GEMINI_API_KEY=your-gemini-api-key

# Server
PORT=5000

# CORS (comma-separated origins, or leave empty for all in dev)
CORS_ORIGIN=http://localhost:5173

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Database (connection pooling)
DATABASE_URL=postgresql://user:password@host:5432/dbname?pgbouncer=true

# Database (direct connection for Prisma migrations)
DIRECT_URL=postgresql://user:password@host:5432/dbname

# Stripe (optional, for paid subscriptions)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_TEAM_PRICE_ID=price_your-team-price-id
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Frontend URL (for Stripe redirect URLs)
FRONTEND_URL=http://localhost:5173

# ComfyUI (optional, for image generation)
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_HOST=localhost:8188
