generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String         @id
  email          String         @unique
  role           String         @default("user")
  stripeCustomerId String?      @unique
  subscription   Subscription?
  threads        Thread[]
  credit         Credit?
  executions     Execution[]
  workflows      Workflow[]
  workflowExecutions WorkflowExecution[]
  agents         Agent[]
  agentRuns      AgentRun[]
  creditTransactions CreditTransaction[]
  createdAt      DateTime       @default(now())
}

model Subscription {
  id                 String    @id @default(uuid())
  userId             String    @unique
  stripeSubscriptionId String? @unique
  stripePriceId      String?
  status             String    @default("free") // free, active, canceled, past_due
  currentPeriodEnd   DateTime?
  user               User      @relation(fields: [userId], references: [id])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Thread {
  id           String     @id @default(uuid())
  userId       String
  title        String     @default("New Conversation")
  systemPrompt String?
  shareToken   String?    @unique
  user         User       @relation(fields: [userId], references: [id])
  messages     Message[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([userId])
  @@index([shareToken])
}

model Message {
  id        String     @id @default(uuid())
  threadId  String
  role      String
  content   String
  tokens    Int?
  editedAt  DateTime?
  thread    Thread     @relation(fields: [threadId], references: [id], onDelete: Cascade)
  feedbacks Feedback[]
  createdAt DateTime   @default(now())

  @@index([threadId])
}

model Feedback {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  rating    Int      // 1 = thumbs up, -1 = thumbs down
  comment   String?
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
}

model Execution {
  id          String    @id @default(uuid())
  userId      String
  type        String    // "chat" | "image" | "video" | "workflow"
  status      String    @default("pending") // pending, running, completed, failed
  provider    String    // "gemini" | "comfyui" | "runpod"
  input       Json
  output      Json?
  creditsUsed Int       @default(0)
  error       String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model Credit {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(100)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model CreditTransaction {
  id          String   @id @default(uuid())
  userId      String
  amount      Int      // negative = spend, positive = add
  reason      String   // "daily_grant" | "chat" | "image_gen" | "purchase"
  executionId String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Workflow {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  graph       Json     // { nodes: [...], edges: [...] }
  isPublic    Boolean  @default(false)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  executions  WorkflowExecution[]

  @@index([userId])
  @@index([isPublic])
}

model WorkflowExecution {
  id            String   @id @default(uuid())
  workflowId    String
  userId        String
  status        String   @default("pending") // pending, running, completed, failed
  input         Json?
  output        Json?
  nodeStates    Json?    // { nodeId: { status, output, error } }
  creditsUsed   Int      @default(0)
  error         String?
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  workflow      Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id])

  @@index([workflowId])
  @@index([userId])
  @@index([status])
}

model Agent {
  id          String   @id @default(uuid())
  userId      String
  name        String
  type        String   // "planner" | "generator" | "editor" | "qa" | "publisher" | "custom"
  description String?
  config      Json     // { model, systemPrompt, tools, ... }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  runs        AgentRun[]

  @@index([userId])
  @@index([type])
}

model AgentRun {
  id            String   @id @default(uuid())
  agentId       String
  userId        String
  status        String   @default("pending") // pending, running, completed, failed, paused
  input         Json?
  output        Json?
  logs          Json?    // [{ timestamp, level, message }]
  creditsUsed   Int      @default(0)
  error         String?
  parentRunId   String?  // for sub-tasks
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id])

  @@index([agentId])
  @@index([userId])
  @@index([status])
  @@index([parentRunId])
}
